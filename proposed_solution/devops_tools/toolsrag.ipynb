   "source": [
    "%%writefile devops_rag.py\n",
    "import os\n",
    "import re\n",
    "from typing import List, Dict, Any, Optional, Tuple\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from difflib import get_close_matches\n",
    "\n",
    "# ---------- Optional dependencies ----------\n",
    "try:\n",
    "    from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "    from sklearn.metrics.pairwise import cosine_similarity\n",
    "    _HAS_SKLEARN = True\n",
    "except Exception:\n",
    "    _HAS_SKLEARN = False\n",
    "\n",
    "# Optional OpenAI embeddings (set OPENAI_API_KEY in env)\n",
    "_USE_OPENAI = False\n",
    "try:\n",
    "    from openai import OpenAI\n",
    "    if os.getenv(\"OPENAI_API_KEY\"):\n",
    "        _OPENAI_CLIENT = OpenAI()\n",
    "        _USE_OPENAI = True\n",
    "except Exception:\n",
    "    _USE_OPENAI = False\n",
    "\n",
    "# ---------- Utilities ----------\n",
    "def _norm(s: str) -> str:\n",
    "    return str(s).strip()\n",
    "\n",
    "def _norm_key(s: str) -> str:\n",
    "    return str(s).strip().lower()\n",
    "\n",
    "def _slug(s: str) -> str:\n",
    "    return re.sub(r\"[^a-z0-9]+\", \"\", str(s).lower())\n",
    "\n",
    "def _dedup_preserve_order(items: List[str]) -> List[str]:\n",
    "    seen = set()\n",
    "    out = []\n",
    "    for x in items:\n",
    "        if x not in seen:\n",
    "            out.append(x)\n",
    "            seen.add(x)\n",
    "    return out\n",
    "\n",
    "# ---------- Core ----------\n",
    "class DevOpsToolsRAG:\n",
    "    \"\"\"\n",
    "    RAG over a cleaned dataset.\n",
    "\n",
    "    Required columns in df:\n",
    "      - paper_id\n",
    "      - category\n",
    "      - subcategory\n",
    "      - tool\n",
    "      - usage\n",
    "\n",
    "    Optional columns:\n",
    "      - paper_citation  (string, e.g., \"journal\", \"conference\", ...)\n",
    "    \"\"\"\n",
    "    def __init__(\n",
    "        self,\n",
    "        df: pd.DataFrame,\n",
    "        use_openai: Optional[bool] = None,\n",
    "        extra_refs_path: Optional[str] = None,  # kept for API compatibility; not used\n",
    "    ):\n",
    "        needed = {\"paper_id\", \"category\", \"subcategory\", \"tool\", \"usage\"}\n",
    "        if not needed.issubset(df.columns):\n",
    "            raise ValueError(f\"Missing required columns: {needed - set(df.columns)}\")\n",
    "\n",
    "        self.df = df.copy()\n",
    "\n",
    "        # Normalize string columns\n",
    "        for c in [\"category\", \"subcategory\", \"tool\", \"usage\"]:\n",
    "            self.df[c] = self.df[c].astype(str).apply(_norm)\n",
    "\n",
    "        # --- SAFE paper_id parsing (nullable Int64; tolerate NaNs) ---\n",
    "        pid = self.df[\"paper_id\"].astype(str).str.extract(r\"(\\d+)\", expand=False)\n",
    "        self.df[\"paper_id\"] = pd.to_numeric(pid, errors=\"coerce\").astype(\"Int64\")\n",
    "\n",
    "        # Ensure paper_citation exists and is string\n",
    "        if \"paper_citation\" not in self.df.columns:\n",
    "            self.df[\"paper_citation\"] = \"unknown\"\n",
    "        else:\n",
    "            self.df[\"paper_citation\"] = self.df[\"paper_citation\"].astype(str).apply(_norm)\n",
    "\n",
    "        # Precompute expanded IDs per row (internal only; ignore NA)\n",
    "        def _expand_ids(pid_val):\n",
    "            out: List[int] = []\n",
    "            if pd.notna(pid_val):\n",
    "                out.append(int(pid_val))\n",
    "            return out\n",
    "\n",
    "        self.df[\"_paper_ids_expanded\"] = self.df[\"paper_id\"].apply(_expand_ids)\n",
    "\n",
    "        # Build per-tool aggregate index (IDs are internal; outputs show only citations)\n",
    "        def _agg_ids(series):\n",
    "            vals = [int(v) for v in series.dropna().astype(\"int64\").tolist()]\n",
    "            return sorted(set(vals))\n",
    "\n",
    "        def _agg_ids_expanded(series_of_lists):\n",
    "            bag = set()\n",
    "            for lst in series_of_lists:\n",
    "                for v in lst:\n",
    "                    bag.add(int(v))\n",
    "            return sorted(bag)\n",
    "\n",
    "        self.tool_index = (\n",
    "            self.df.groupby(\"tool\", dropna=False)\n",
    "            .agg(\n",
    "                {\n",
    "                    \"category\": lambda x: sorted(set(x)),\n",
    "                    \"subcategory\": lambda x: sorted(set(x)),\n",
    "                    \"usage\": lambda x: _dedup_preserve_order(\n",
    "                        [u for u in x if isinstance(u, str) and u.strip()]\n",
    "                    ),\n",
    "                    # Internals (IDs) kept for scoring/debug; not shown in outputs\n",
    "                    \"paper_id\": _agg_ids,\n",
    "                    \"_paper_ids_expanded\": _agg_ids_expanded,\n",
    "                    # What we will SHOW\n",
    "                    \"paper_citation\": lambda x: sorted(set(x)),\n",
    "                }\n",
    "            )\n",
    "            .reset_index()\n",
    "        )\n",
    "\n",
    "        # Alias tables for robust lookup\n",
    "        self._tool_names = self.tool_index[\"tool\"].tolist()\n",
    "        self._alias_case = {_norm_key(t): t for t in self._tool_names}\n",
    "        self._alias_slug = {_slug(t): t for t in self._tool_names}\n",
    "\n",
    "        # Retrieval corpus (includes citations text for better recall)\n",
    "        self.tool_index[\"corpus\"] = (\n",
    "            self.tool_index[\"tool\"].astype(str)\n",
    "            + \" | \"\n",
    "            + self.tool_index[\"category\"].apply(lambda xs: \" ; \".join(xs))\n",
    "            + \" | \"\n",
    "            + self.tool_index[\"subcategory\"].apply(lambda xs: \" ; \".join(xs))\n",
    "            + \" | \"\n",
    "            + self.tool_index[\"usage\"].apply(lambda xs: \" ; \".join(xs))\n",
    "            + \" | \"\n",
    "            + self.tool_index[\"paper_citation\"].apply(lambda xs: \" ; \".join(xs))\n",
    "        )\n",
    "\n",
    "        # Engines\n",
    "        self._use_openai = _USE_OPENAI if use_openai is None else use_openai\n",
    "        self._build_vector_spaces()\n",
    "\n",
    "        # Dictionaries for guided query expansion\n",
    "        self.categories = sorted(self.df[\"category\"].dropna().unique())\n",
    "        self.subcategories = sorted(self.df[\"subcategory\"].dropna().unique())\n",
    "\n",
    "        # Simple synonyms\n",
    "        self.synonyms = {\n",
    "            \"k8s\": \"kubernetes\",\n",
    "            \"image scanning\": \"vulnerability scanning\",\n",
    "            \"code repo\": \"source code management\",\n",
    "            \"git repo\": \"source code management\",\n",
    "            \"sast\": \"static application security testing\",\n",
    "            \"dast\": \"dynamic application security testing\",\n",
    "            \"sca\": \"software composition analysis\",\n",
    "            \"ci\": \"continuous integration\",\n",
    "            \"cd\": \"continuous delivery continuous deployment\",\n",
    "            \"policy\": \"policy enforcement\",\n",
    "        }\n",
    "\n",
    "    # ---------- Vector spaces ----------\n",
    "    def _build_vector_spaces(self):\n",
    "        texts = self.tool_index[\"corpus\"].tolist()\n",
    "\n",
    "        self._tfidf = None\n",
    "        self._tfidf_mat = None\n",
    "        if _HAS_SKLEARN:\n",
    "            self._tfidf = TfidfVectorizer(ngram_range=(1, 2), stop_words=\"english\", min_df=1)\n",
    "            self._tfidf_mat = self._tfidf.fit_transform(texts)\n",
    "\n",
    "        self._embeddings = None\n",
    "        if self._use_openai:\n",
    "            self._embeddings = self._embed_batch_openai(texts)\n",
    "\n",
    "    def _embed_openai(self, text: str) -> np.ndarray:\n",
    "        resp = _OPENAI_CLIENT.embeddings.create(model=\"text-embedding-3-small\", input=[text])\n",
    "        return np.array(resp.data[0].embedding, dtype=np.float32)\n",
    "\n",
    "    def _embed_batch_openai(self, texts: List[str]) -> np.ndarray:\n",
    "        all_vecs = []\n",
    "        B = 256\n",
    "        for i in range(0, len(texts), B):\n",
    "            batch = texts[i : i + B]\n",
    "            resp = _OPENAI_CLIENT.embeddings.create(model=\"text-embedding-3-small\", input=batch)\n",
    "            vecs = [np.array(r.embedding, dtype=np.float32) for r in resp.data]\n",
    "            all_vecs.extend(vecs)\n",
    "        return np.vstack(all_vecs)\n",
    "\n",
    "    @staticmethod\n",
    "    def _cosine_np(A: np.ndarray, b: np.ndarray) -> np.ndarray:\n",
    "        A_norm = A / (np.linalg.norm(A, axis=1, keepdims=True) + 1e-12)\n",
    "        b_norm = b / (np.linalg.norm(b) + 1e-12)\n",
    "        return A_norm @ b_norm\n",
    "\n",
    "    # ---------- Query prep ----------\n",
    "    def _expand_query(self, text: str) -> str:\n",
    "        t = text.strip()\n",
    "        lower = t.lower()\n",
    "        expanded = [t]\n",
    "        for k, v in self.synonyms.items():\n",
    "            if k in lower:\n",
    "                expanded.append(v)\n",
    "        for cat in self.categories:\n",
    "            if cat.lower() in lower:\n",
    "                expanded.append(cat)\n",
    "        for sub in self.subcategories:\n",
    "            if sub.lower() in lower:\n",
    "                expanded.append(sub)\n",
    "        return \" ; \".join(_dedup_preserve_order(expanded))\n",
    "\n",
    "    # ---------- Lookups ----------\n",
    "    def lookup_tool(self, tool_query: str, top_k: int = 5) -> Dict[str, Any]:\n",
    "        q = tool_query.strip()\n",
    "        q_case = _norm_key(q)\n",
    "        q_slug = _slug(q)\n",
    "\n",
    "        # exact\n",
    "        if q_case in self._alias_case:\n",
    "            t = self._alias_case[q_case]\n",
    "        elif q_slug in self._alias_slug:\n",
    "            t = self._alias_slug[q_slug]\n",
    "        else:\n",
    "            # fuzzy\n",
    "            candidates = get_close_matches(q, self._tool_names, n=top_k, cutoff=0.6)\n",
    "            results = []\n",
    "            for c in candidates:\n",
    "                row = self.tool_index[self.tool_index[\"tool\"] == c].iloc[0]\n",
    "                results.append({\n",
    "                    \"tool\": c,\n",
    "                    \"categories\": row[\"category\"],\n",
    "                    \"subcategories\": row[\"subcategory\"],\n",
    "                    \"paper_citations\": row[\"paper_citation\"],\n",
    "                })\n",
    "            return {\"query\": q, \"closest_matches\": results}\n",
    "\n",
    "        row = self.tool_index[self.tool_index[\"tool\"] == t].iloc[0]\n",
    "        return {\n",
    "            \"tool\": t,\n",
    "            \"categories\": row[\"category\"],\n",
    "            \"subcategories\": row[\"subcategory\"],\n",
    "            \"paper_citations\": row[\"paper_citation\"],\n",
    "        }\n",
    "\n",
    "    # ---------- Recommendations ----------\n",
    "    def recommend(self, request_text: str, top_k: int = 10, blend: float = 0.5) -> List[Dict[str, Any]]:\n",
    "        q = self._expand_query(request_text)\n",
    "        scores = np.zeros(len(self.tool_index), dtype=np.float32)\n",
    "        used_any = False\n",
    "\n",
    "        if _HAS_SKLEARN and self._tfidf is not None:\n",
    "            qv = self._tfidf.transform([q])\n",
    "            tfidf_scores = cosine_similarity(self._tfidf_mat, qv).ravel().astype(np.float32)\n",
    "            scores += (1.0 - blend) * tfidf_scores\n",
    "            used_any = True\n",
    "\n",
    "        if self._embeddings is not None and self._use_openai:\n",
    "            qemb = self._embed_openai(q)\n",
    "            emb_scores = self._cosine_np(self._embeddings, qemb).astype(np.float32)\n",
    "            scores += blend * emb_scores\n",
    "            used_any = True\n",
    "\n",
    "        if not used_any:\n",
    "            raise RuntimeError(\"No vectorizer available. Install scikit-learn or set OPENAI_API_KEY.\")\n",
    "\n",
    "        # name boost\n",
    "        qname = request_text.lower().strip()\n",
    "        if qname:\n",
    "            tool_names_lower = self.tool_index[\"tool\"].str.lower().tolist()\n",
    "            for i, name in enumerate(tool_names_lower):\n",
    "                if qname in name:\n",
    "                    scores[i] += 1.0\n",
    "\n",
    "        idx = np.argsort(-scores, kind=\"stable\")[:top_k]\n",
    "\n",
    "        out: List[Dict[str, Any]] = []\n",
    "        for i in idx:\n",
    "            row = self.tool_index.iloc[i]\n",
    "            out.append({\n",
    "                \"tool\": row[\"tool\"],\n",
    "                \"score\": float(scores[i]),\n",
    "                \"categories\": row[\"category\"],\n",
    "                \"subcategories\": row[\"subcategory\"],\n",
    "                \"paper_citations\": row[\"paper_citation\"],\n",
    "                \"top_usages\": row[\"usage\"][:5],\n",
    "            })\n",
    "        return out\n",
    "\n",
    "    # ---------- Pretty printers (hide IDs in displays) ----------\n",
    "    def format_lookup(self, result: Dict[str, Any]) -> Tuple[Optional[pd.DataFrame], Optional[pd.DataFrame]]:\n",
    "        if \"tool\" in result:\n",
    "            summary = pd.DataFrame({\n",
    "                \"Tool\": [result[\"tool\"]],\n",
    "                \"Categories\": [\", \".join(result[\"categories\"])],\n",
    "                \"Subcategories\": [\", \".join(result[\"subcategories\"])],\n",
    "                \"Paper Citations\": [\", \".join(result[\"paper_citations\"])],\n",
    "            })\n",
    "            details = (\n",
    "                self.df[self.df[\"tool\"] == result[\"tool\"]][\n",
    "                    [\"paper_citation\", \"category\", \"subcategory\", \"usage\"]\n",
    "                ]\n",
    "                .drop_duplicates()\n",
    "                .sort_values([\"paper_citation\", \"category\", \"subcategory\"])\n",
    "                .reset_index(drop=True)\n",
    "            )\n",
    "            return summary, details\n",
    "        else:\n",
    "            rows = []\n",
    "            for m in result.get(\"closest_matches\", []):\n",
    "                rows.append({\n",
    "                    \"Tool\": m[\"tool\"],\n",
    "                    \"Categories\": \", \".join(m[\"categories\"]),\n",
    "                    \"Subcategories\": \", \".join(m[\"subcategories\"]),\n",
    "                    \"Paper Citations\": \", \".join(m[\"paper_citations\"]),\n",
    "                })\n",
    "            summary = pd.DataFrame(rows) if rows else None\n",
    "            return summary, None\n",
    "\n",
    "    def format_recommendations(self, recs: List[Dict[str, Any]], min_score: float = None) -> pd.DataFrame:\n",
    "     if min_score is not None:\n",
    "        recs = [r for r in recs if r[\"score\"] > min_score]  # strict \"more than\"\n",
    "\n",
    "     rows = []\n",
    "     for r in recs:\n",
    "        rows.append({\n",
    "            \"Tool\": r[\"tool\"],\n",
    "            \"Score\": round(r[\"score\"], 4),\n",
    "            \"Categories\": \", \".join(r[\"categories\"]),\n",
    "            \"Subcategories\": \", \".join(r[\"subcategories\"]),\n",
    "            \"Paper Citations\": \", \".join(r[\"paper_citations\"]),\n",
    "            \"Sample Usages\": \" | \".join(r[\"top_usages\"]),\n",
    "        })\n",
    "     cols = [\"Tool\",\"Score\",\"Categories\",\"Subcategories\",\"Paper Citations\",\"Sample Usages\"]\n",
    "     return pd.DataFrame(rows)[cols]\n"
   ]
  },
